# Eval harness configuration. Copy to evals/.env and fill in. Never commit .env.

# --- MCP target ---
FR_MCP_URL=https://mcp.financialfilings.com/mcp
# Bearer token for the MCP. Two ways to get one (see README):
#  (B) grab a token from a Claude Code session / one browser login (expires ~1h)
#  (A) mint from a test account:  export FR_MCP_TOKEN="$(python cognito_token.py)"
FR_MCP_TOKEN=

# --- Claude adapter + judge ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-7
JUDGE_MODEL=claude-opus-4-7

# --- DeepSeek V4 Flash via Ollama Cloud (OpenAI-compatible) ---
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_MODEL=deepseek-v4-flash:cloud

# --- Token path A only (cognito_token.py) ---
# COGNITO_CLIENT_ID=        # the app client id the MCP accepts (ask the FR team)
# COGNITO_REGION=eu-central-1
# FR_TEST_USERNAME=
# FR_TEST_PASSWORD=

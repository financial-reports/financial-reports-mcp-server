# --- Required: AWS Cognito (the OAuth proxy backbone) ---
COGNITO_USER_POOL_ID=eu-central-1_xxxxxxxxx
COGNITO_CLIENT_ID=your_cognito_app_client_id
COGNITO_CLIENT_SECRET=your_cognito_app_client_secret

# --- Optional ---
# AWS region of the Cognito user pool (default: eu-central-1)
COGNITO_REGION=eu-central-1

# Public base URL of THIS MCP server (default: https://mcp.financialfilings.com)
# Must match the Cognito app client's allowed redirect URIs.
MCP_BASE_URL=https://mcp.financialfilings.com

# Backend the tool wrappers call into (default: https://api.financialreports.eu)
API_BASE_URL=https://api.financialreports.eu

# Subscription-verification endpoint on the FinancialReports Django backend
# (default: https://api.financialreports.eu/api/mcp/verify/)
VERIFY_URL=https://api.financialreports.eu/api/mcp/verify/

# Where free-tier users are redirected to upgrade
UPGRADE_URL=https://financialreports.eu/pricing/?utm_source=mcp&utm_medium=connector

# Where the landing page's "Documentation" link points
# (default: https://financialreports.eu/integrations/claude/)
LANDING_URL=https://financialreports.eu/integrations/claude/

# Public-facing legal/support URLs surfaced as the landing-page footer.
# All four are required by Anthropic's connector directory submission.
PRIVACY_URL=https://financialreports.eu/data-privacy/
TERMS_URL=https://financialreports.eu/terms/
IMPRINT_URL=https://financialreports.eu/imprint/
SUPPORT_URL=https://financialreports.eu/contact/

# Stamped into the User-Agent header and the /health response. The deploy
# pipeline overrides this with the SDK release tag at image build time
# (Docker ARG MCP_VERSION); locally it defaults to "dev".
# MCP_VERSION=dev

# Logging level (DEBUG, INFO, WARNING, ERROR; default: INFO)
LOG_LEVEL=INFO

# Optional. When set, FastMCP's OAuth proxy stores its state (client
# registrations, codes, refresh tokens) in Redis instead of the per-replica
# DiskStore. Required for users to stay signed in across deploys / horizontal
# scaling on Azure Container Apps. Use a dedicated DB number to avoid
# colliding with Celery (DB 0) or the Django cache (DB 1). At boot the
# server pings Redis and fails the revision if it is unreachable.
# MCP_REDIS_URL=rediss://:<auth-token>@<endpoint>:<ssl-port>/3?ssl_cert_reqs=required

# --- DEV-ONLY: bypass Cognito OAuth and use a personal API key ---
# When set, the JWT-validation decorator is skipped and this key is forwarded
# as the bearer token to API_BASE_URL. Refuses to activate if MCP_BASE_URL
# contains a production hostname (mcp.financialfilings.com). Never set in
# production.
# DEV_MODE_API_KEY=fr_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
